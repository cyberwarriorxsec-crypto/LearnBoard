/* ════════════════════════════════════════════════
   RENDER COURSES
════════════════════════════════════════════════ */

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ════════════════════════════════════════════════
   STATUS FILTER TABS
════════════════════════════════════════════════ */

function setStatusFilter(status) {
  activeStatusFilter = status;
  // Update tab active states
  document.querySelectorAll('.filter-tab').forEach(btn => {
    const isActive = btn.dataset.status === status;
    btn.classList.toggle('active', isActive);
  });
  renderCourses();
}

function updateTabCounts() {
  const all        = courses.length;
  const inProgress = courses.filter(c => getStatus(c) === 'In Progress').length;
  const notStarted = courses.filter(c => getStatus(c) === 'Not Started').length;
  const completed  = courses.filter(c => getStatus(c) === 'Completed').length;

  const el = (id) => document.getElementById(id);
  if (el('tab-count-all'))        el('tab-count-all').textContent        = all;
  if (el('tab-count-inprogress')) el('tab-count-inprogress').textContent = inProgress;
  if (el('tab-count-notstarted')) el('tab-count-notstarted').textContent = notStarted;
  if (el('tab-count-completed'))  el('tab-count-completed').textContent  = completed;
}

function renderCourses() {
  const grid = document.getElementById('course-grid');
  const filterCat  = document.getElementById('filter-category').value;
  const sortMode   = document.getElementById('sort-courses').value;

  // 1. Filter by category
  let list = filterCat ? courses.filter(c => c.category === filterCat) : [...courses];

  // 2. Filter by status tab
  if (activeStatusFilter !== 'all') {
    list = list.filter(c => getStatus(c) === activeStatusFilter);
  }

  // 3. Update tab counts (always from full list, ignoring category for counts)
  updateTabCounts();

  // 4. Sort
  switch (sortMode) {
    case 'name-asc':       list.sort((a,b) => a.name.localeCompare(b.name)); break;
    case 'name-desc':      list.sort((a,b) => b.name.localeCompare(a.name)); break;
    case 'progress-desc':  list.sort((a,b) => pct(b) - pct(a)); break;
    case 'progress-asc':   list.sort((a,b) => pct(a) - pct(b)); break;
    case 'updated':        list.sort((a,b) => new Date(b.lastUpdated||0) - new Date(a.lastUpdated||0)); break;
    case 'added':          list.sort((a,b) => new Date(b.createdAt||0) - new Date(a.createdAt||0)); break;
    default: break; // keep insertion order
  }

  if (list.length === 0) {
    const emptyMsgs = {
      'all':          { icon: '📚', title: 'No courses yet', sub: 'Add your first course to get started.', btn: true },
      'In Progress':  { icon: '⏳', title: 'No courses in progress', sub: 'Start a course to see it here.', btn: false },
      'Not Started':  { icon: '🚀', title: 'No unstarted courses', sub: 'All your courses have been started!', btn: false },
      'Completed':    { icon: '🎉', title: 'No completed courses yet', sub: 'Keep going — you\'re almost there!', btn: false },
    };
    const m = emptyMsgs[activeStatusFilter] || emptyMsgs['all'];
    grid.innerHTML = `
      <div class="col-span-full empty-state">
        <div class="text-5xl mb-4">${m.icon}</div>
        <p class="text-slate-400 font-medium mb-1">${m.title}</p>
        <p class="text-slate-600 text-sm mb-5">${m.sub}</p>
        ${m.btn ? `<button class="btn btn-primary" onclick="openModal()"><i class="fa fa-plus"></i> Add Course</button>` : ''}
      </div>`;
    return;
  }

  grid.innerHTML = list.map(c => {
    const p       = pct(c);
    const status  = getStatus(c);
    const isComplete = status === 'Completed';
    const hasNotes = c.notes && c.notes.trim().length > 0;

    return `
    <div class="card p-5 flex flex-col gap-4" id="card-${c.id}">
      <!-- Top row: category + status + actions -->
      <div class="flex items-start justify-between gap-2">
        <div class="flex flex-wrap gap-1.5">
          <span class="badge text-xs px-2 py-0.5 rounded-full ${catClass(c.category)}" style="border:1px solid transparent">${esc(c.category)}</span>
          <span class="badge ${badgeClass(status)}">${status}</span>
        </div>
        <div class="flex items-center gap-1 shrink-0">
          <button class="btn-icon" title="Notes" onclick="openNotesModal('${c.id}')">
            <i class="fa fa-note-sticky ${hasNotes ? 'text-violet-400' : ''}"></i>
          </button>
          <button class="btn-icon" title="Edit" onclick="openModal('${c.id}')">
            <i class="fa fa-pen"></i>
          </button>
          <button class="btn-icon" title="Delete" onclick="deleteCourse('${c.id}')" style="color:var(--red);opacity:.6">
            <i class="fa fa-trash"></i>
          </button>
        </div>
      </div>

      <!-- Name + platform -->
      <div>
        <h3 class="font-semibold text-slate-100 leading-tight mb-0.5 text-[15px]">${esc(c.name)}</h3>
        ${c.platform ? `<p class="text-xs text-slate-500">${esc(c.platform)}</p>` : ''}
      </div>

      <!-- Progress bar -->
      <div>
        <div class="flex justify-between items-center mb-1.5">
          <span class="text-xs text-slate-500">Progress</span>
          <span class="mono text-xs font-bold ${isComplete ? 'text-emerald-400' : 'text-violet-400'}">${p}%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill ${isComplete ? 'complete' : ''}" style="width:${p}%"></div>
        </div>
        <p class="text-xs text-slate-600 mt-1">${c.completed} / ${c.total} lessons${c.estHours ? ` · ~${c.estHours}h est.` : ''}</p>
      </div>

      <!-- Lesson counter -->
      <div class="flex items-center gap-2 mt-auto">
        <button class="btn-icon" title="Remove lesson" onclick="decrementLesson('${c.id}')" ${c.completed <= 0 ? 'disabled style="opacity:.3"' : ''}>
          <i class="fa fa-minus"></i>
        </button>
        <div class="flex-1 text-center">
          <span class="mono text-lg font-bold text-slate-200">${c.completed}</span>
          <span class="text-slate-600 text-sm">/${c.total}</span>
        </div>
        <button class="btn-icon emerald" title="Add lesson" onclick="incrementLesson('${c.id}')" ${c.completed >= c.total ? 'disabled style="opacity:.3"' : ''}>
          <i class="fa fa-plus"></i>
        </button>
        ${!isComplete ? `
        <button class="btn btn-ghost text-xs px-2 py-1" onclick="incrementLesson('${c.id}')" title="Log lesson">
          <i class="fa fa-check text-emerald-400"></i> Done
        </button>` : ''}
      </div>

      <!-- Notes preview -->
      ${hasNotes ? `
      <div class="notes-section border-t border-[var(--border)] pt-3">
        <p class="text-xs text-slate-500 mb-1"><i class="fa fa-note-sticky text-violet-400 mr-1"></i>Notes</p>
        <pre class="text-xs text-slate-400 leading-relaxed whitespace-pre-wrap break-words" style="font-family:var(--mono);max-height:80px;overflow:hidden;mask-image:linear-gradient(180deg,#fff 60%,transparent)">${esc(c.notes)}</pre>
        <button class="text-xs text-violet-400 hover:text-violet-300 mt-1" onclick="openNotesModal('${c.id}')">Edit notes →</button>
      </div>` : ''}
    </div>`;
  }).join('');
}

function renderAll() {
  renderStats();
  renderStreak();
  renderUpNext();
  renderCourses();
}

/* ════════════════════════════════════════════════
   POMODORO TIMER
════════════════════════════════════════════════ */

const POMO_DURATIONS = {
  focus: 25 * 60,
  shortBreak: 5 * 60,
  longBreak: 15 * 60,
};

let pomoState = {
  running:    false,
  mode:       'focus',   // 'focus' | 'shortBreak' | 'longBreak'
  remaining:  POMO_DURATIONS.focus,
  sessionNum: 1,         // 1-4 focus sessions before long break
  interval:   null,
};

function pomodoroToggle() {
  if (pomoState.running) {
    clearInterval(pomoState.interval);
    pomoState.running = false;
    document.getElementById('pomo-play').innerHTML = '<i class="fa fa-play"></i> Start';
    document.getElementById('pomo-play').classList.remove('active');
  } else {
    pomoState.running = true;
    document.getElementById('pomo-play').innerHTML = '<i class="fa fa-pause"></i> Pause';
    document.getElementById('pomo-play').classList.add('active');
    pomoState.interval = setInterval(pomodoroTick, 1000);
  }
}

function pomodoroTick() {
  if (pomoState.remaining <= 0) {
    clearInterval(pomoState.interval);
    pomoState.running = false;
    pomodoroAdvance();
    return;
  }
  pomoState.remaining--;
  updatePomoUI();
}

function pomodoroAdvance() {
  if (pomoState.mode === 'focus') {
    // record study session if any progress was made
    if (pomoState.sessionNum < 4) {
      pomoState.mode = 'shortBreak';
      pomoState.remaining = POMO_DURATIONS.shortBreak;
      toast('Focus session done! Take a 5-min break 🌿', 'success');
    } else {
      pomoState.mode = 'longBreak';
      pomoState.sessionNum = 0;
      pomoState.remaining = POMO_DURATIONS.longBreak;
      toast('4 sessions done! Take a 15-min break 🎉', 'success');
    }
  } else {
    pomoState.sessionNum++;
    pomoState.mode = 'focus';
    pomoState.remaining = POMO_DURATIONS.focus;
    toast('Break over — time to focus! 🔥', 'info');
  }
  document.getElementById('pomo-play').innerHTML = '<i class="fa fa-play"></i> Start';
  document.getElementById('pomo-play').classList.remove('active');
  updatePomoUI();
}

function pomodoroReset() {
  clearInterval(pomoState.interval);
  pomoState.running   = false;
  pomoState.mode      = 'focus';
  pomoState.remaining = POMO_DURATIONS.focus;
  pomoState.sessionNum = 1;
  document.getElementById('pomo-play').innerHTML = '<i class="fa fa-play"></i> Start';
  document.getElementById('pomo-play').classList.remove('active');
  updatePomoUI();
}

function pomodoroSkip() {
  clearInterval(pomoState.interval);
  pomoState.running = false;
  pomodoroAdvance();
}

function updatePomoUI() {
  const m = Math.floor(pomoState.remaining / 60).toString().padStart(2, '0');
  const s = (pomoState.remaining % 60).toString().padStart(2, '0');
  document.getElementById('pomo-display').textContent = `${m}:${s}`;

  const total = POMO_DURATIONS[pomoState.mode];
  const ratio = (total - pomoState.remaining) / total;
  const circ  = 251.2;
  const offset = circ - (ratio * circ);
  const arc = document.getElementById('pomo-arc');
  arc.style.strokeDashoffset = offset;
  arc.classList.toggle('break', pomoState.mode !== 'focus');

  const modeLabel = document.getElementById('pomo-mode-label');
  modeLabel.textContent = pomoState.mode === 'focus' ? 'Focus' : pomoState.mode === 'shortBreak' ? 'Short Break' : 'Long Break';
  modeLabel.className   = 'ml-auto badge ' + (pomoState.mode === 'focus' ? 'badge-in-progress' : 'badge-completed');

  document.getElementById('pomo-session-label').textContent =
    `Session ${pomoState.sessionNum} of 4 · ${4 - pomoState.sessionNum === 0 ? 'then long break' : `${4 - pomoState.sessionNum} left`}`;
}

/* ════════════════════════════════════════════════
   TOAST
════════════════════════════════════════════════ */

function toast(msg, type = 'info') {
  const icons = { success: '✅', info: 'ℹ️' };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<span>${icons[type] || 'ℹ️'}</span><span>${msg}</span>`;
  document.getElementById('toast-container').appendChild(el);
  requestAnimationFrame(() => { requestAnimationFrame(() => { el.classList.add('show'); }); });
  setTimeout(() => {
    el.classList.remove('show');
    setTimeout(() => el.remove(), 350);
  }, 3000);
}

